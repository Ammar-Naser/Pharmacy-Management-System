CREATE DATABASE pharmacy_db;
USE pharmacy_db;
GO

-- EMPLOYEES
CREATE TABLE EMPLOYEES (
    ssn INT PRIMARY KEY,
    name VARCHAR(100) NOT NULL,
    salary FLOAT NOT NULL
);

-- CUSTOMERS
CREATE TABLE CUSTOMERS (
    id INT IDENTITY(1,1) PRIMARY KEY,
    name VARCHAR(100) NOT NULL,
    phone VARCHAR(20),
    loyalty_points INT DEFAULT 0
);

-- DRUG CATEGORY
CREATE TABLE DRUG_CATEGORY (
    id INT IDENTITY(1,1) PRIMARY KEY,
    name VARCHAR(100) NOT NULL
);

-- DRUGS
CREATE TABLE DRUGS (
    code INT PRIMARY KEY,
    name VARCHAR(100) NOT NULL,
    price FLOAT NOT NULL,
    expiry_date DATE,
    category_id INT,
    stock INT DEFAULT 0,

    FOREIGN KEY (category_id) REFERENCES DRUG_CATEGORY(id)
);

-- INVOICE
CREATE TABLE INVOICE (
    inv_id INT IDENTITY(1,1) PRIMARY KEY,
    customer_id INT,
    employee_ssn INT,
    total_amount FLOAT,

    FOREIGN KEY (customer_id) REFERENCES CUSTOMERS(id),
    FOREIGN KEY (employee_ssn) REFERENCES EMPLOYEES(ssn)
);

-- INVOICE ITEM
CREATE TABLE INVOICE_ITEM (
    inv_id INT,
    item_no INT,
    drug_code INT,
    quantity INT,

    PRIMARY KEY (inv_id, item_no),

    FOREIGN KEY (inv_id) REFERENCES INVOICE(inv_id),
    FOREIGN KEY (drug_code) REFERENCES DRUGS(code)
);

