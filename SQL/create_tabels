);

--SUPPLIES
CREATE TABLE SUPPLIES (
    supplier_id INT,
    drug_code INT,
    supply_quantity INT,

    PRIMARY KEY (supplier_id, drug_code),

    FOREIGN KEY (supplier_id) REFERENCES SUPPLIER(supplier_id),
    FOREIGN KEY (drug_code) REFERENCES DRUGS(code)
);

--STOCKS
CREATE TABLE STOCKS (
    branch_id INT,
    drug_code INT,
    stock_level INT DEFAULT 0,
    is_out_of_stock BIT DEFAULT 0,

    PRIMARY KEY (branch_id, drug_code),

    FOREIGN KEY (branch_id) REFERENCES BRANCH(branch_id),
    FOREIGN KEY (drug_code) REFERENCES DRUGS(code)
);

